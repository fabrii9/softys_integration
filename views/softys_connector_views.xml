<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Form View -->
    <record id="view_softys_connector_form" model="ir.ui.view">
        <field name="name">softys.connector.form</field>
        <field name="model">softys.connector</field>
        <field name="arch" type="xml">
            <form string="Configuración Softys">
                <header>
                    <button name="action_export_manual" string="Exportar Ahora" type="object" class="oe_highlight"/>
                    <button name="action_view_exports" string="Ver Exportaciones" type="object"/>
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="company_code"/>
                        <h1><field name="company_code" placeholder="001971"/></h1>
                    </div>
                    
                    <group>
                        <group string="Configuración Básica">
                            <field name="company_id"/>
                            <field name="softys_partner_id"/>
                        </group>
                        <group string="Estadísticas">
                            <field name="last_export_date"/>
                            <field name="last_export_status"/>
                            <field name="export_count"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Rutas y Archivos">
                            <group>
                                <group>
                                    <field name="output_path"/>
                                    <field name="output_storage_type"/>
                                </group>
                                <group>
                                    <field name="csv_encoding"/>
                                    <field name="csv_separator"/>
                                    <field name="csv_enclosure"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Códigos Fijos">
                            <group>
                                <group string="Códigos Generales">
                                    <field name="codigo_sucursal"/>
                                    <field name="codigo_fuerza"/>
                                    <field name="codigo_modo_atencion"/>
                                    <field name="codigo_deposito"/>
                                </group>
                                <group string="Códigos por Defecto">
                                    <field name="codigo_ruta_default"/>
                                    <field name="desc_ruta_default"/>
                                    <field name="localidad_default"/>
                                </group>
                            </group>
                            <group>
                                <group string="Provincia por Defecto">
                                    <field name="provincia_codigo_default"/>
                                    <field name="provincia_nombre_default"/>
                                </group>
                                <group string="Fechas Extremas">
                                    <field name="fecha_desde_default"/>
                                    <field name="fecha_hasta_default"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Filtros">
                            <group>
                                <field name="days_back"/>
                            </group>
                        </page>
                        
                        <page string="Personal Comercial">
                            <field name="personal_comercial_ids" nolabel="1"/>
                        </page>
                        
                        <page string="Rutas de Venta">
                            <field name="ruta_venta_ids" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- List View -->
    <record id="view_softys_connector_tree" model="ir.ui.view">
        <field name="name">softys.connector.list</field>
        <field name="model">softys.connector</field>
        <field name="arch" type="xml">
            <list string="Configuraciones Softys">
                <field name="company_code"/>
                <field name="company_id"/>
                <field name="last_export_date"/>
                <field name="last_export_status" widget="badge" 
                       decoration-success="last_export_status == 'success'"
                       decoration-warning="last_export_status == 'partial'"
                       decoration-danger="last_export_status == 'failed'"/>
                <field name="export_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_softys_connector" model="ir.actions.act_window">
        <field name="name">Configuración Softys</field>
        <field name="res_model">softys.connector</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear primera configuración Softys
            </p>
            <p>
                Configure los parámetros de integración con Softys.
            </p>
        </field>
    </record>
    
    <!-- Menu -->
    <menuitem id="menu_softys_connector"
              name="Conector"
              parent="menu_softys_config"
              action="action_softys_connector"
              sequence="10"/>
    
</odoo>

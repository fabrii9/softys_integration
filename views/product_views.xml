<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- VISTA PRODUCT TEMPLATE - Campo Unidades por Bulto            -->
    <!-- ============================================================ -->
    <record id="view_product_template_form_inherit_softys" model="ir.ui.view">
        <field name="name">product.template.form.inherit.softys</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_properties']" position="after">
                <page string="Softys" name="softys">
                    <group>
                        <group string="Datos de exportación">
                            <field name="x_softys_unidades_bulto"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- VISTA PRODUCT PRODUCT - Campo Unidades por Bulto             -->
    <!-- ============================================================ -->
    <record id="view_product_product_form_inherit_softys" model="ir.ui.view">
        <field name="name">product.product.form.inherit.softys</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_properties']" position="after">
                <page string="Softys" name="softys">
                    <group>
                        <group string="Datos de exportación">
                            <field name="x_softys_unidades_bulto"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

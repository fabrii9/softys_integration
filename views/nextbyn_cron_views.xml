<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- CONFIGURACIÓN CRON NEXTBYN - VISTAS -->
    <!-- ============================================================ -->
    
    <!-- List View -->
    <record id="nextbyn_export_cron_view_tree" model="ir.ui.view">
        <field name="name">nextbyn.export.cron.list</field>
        <field name="model">nextbyn.export.cron</field>
        <field name="arch" type="xml">
            <list string="Configuraciones de Cron">
                <field name="name"/>
                <field name="connector_id"/>
                <field name="cron_active" widget="boolean_toggle"/>
                <field name="cron_interval"/>
                <field name="cron_interval_type"/>
                <field name="last_run"/>
                <field name="last_run_status" widget="badge"
                       decoration-success="last_run_status == 'success'"
                       decoration-warning="last_run_status == 'partial'"
                       decoration-danger="last_run_status == 'failed'"/>
                <field name="run_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    
    <!-- Form View -->
    <record id="nextbyn_export_cron_view_form" model="ir.ui.view">
        <field name="name">nextbyn.export.cron.form</field>
        <field name="model">nextbyn.export.cron</field>
        <field name="arch" type="xml">
            <form string="Configuración Cron Nextbyn">
                <header>
                    <button name="action_run_now" type="object" 
                            string="Ejecutar Ahora" class="btn-primary"
                            icon="fa-play"/>
                    <button name="action_create_cron" type="object" 
                            string="Crear Tarea Programada" class="btn-secondary"
                            icon="fa-clock-o"
                            invisible="ir_cron_id"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactivo" bg_color="bg-danger" 
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la configuración"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuración General">
                            <field name="connector_id" options="{'no_create': True}"/>
                            <field name="active"/>
                        </group>
                        <group string="Destino de Archivos">
                            <field name="output_type"/>
                            <field name="output_path" 
                                   placeholder="/var/nextbyn/export"/>
                        </group>
                    </group>
                    <group>
                        <group string="Programación">
                            <field name="ir_cron_id" readonly="1"/>
                            <field name="cron_active" widget="boolean_toggle"
                                   invisible="not ir_cron_id"/>
                            <field name="cron_interval"/>
                            <field name="cron_interval_type"/>
                            <field name="cron_nextcall" invisible="not ir_cron_id"/>
                        </group>
                        <group string="Última Ejecución">
                            <field name="last_run"/>
                            <field name="last_run_status" widget="badge"
                                   decoration-success="last_run_status == 'success'"
                                   decoration-warning="last_run_status == 'partial'"
                                   decoration-danger="last_run_status == 'failed'"/>
                            <field name="run_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Entidades" name="entities">
                            <group>
                                <field name="export_all_entities"/>
                            </group>
                            <field name="entity_ids" widget="many2many_tags"
                                   invisible="export_all_entities"
                                   options="{'color_field': 'color'}"/>
                            <group invisible="not export_all_entities">
                                <div class="alert alert-info" role="alert">
                                    <strong>Exportar todas las entidades activas.</strong>
                                    Desactive esta opción para seleccionar entidades específicas.
                                </div>
                            </group>
                        </page>
                        <page string="Historial" name="history">
                            <group>
                                <field name="last_run_message" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Action -->
    <record id="nextbyn_export_cron_action" model="ir.actions.act_window">
        <field name="name">Programación de Exportaciones</field>
        <field name="res_model">nextbyn.export.cron</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configurar exportación automática
            </p>
            <p>
                Configure aquí las tareas programadas para exportar datos
                automáticamente a Nextbyn.
            </p>
        </field>
    </record>
    
    <!-- Menú -->
    <menuitem id="menu_nextbyn_cron"
              name="Programación"
              parent="menu_softys_config"
              action="nextbyn_export_cron_action"
              sequence="10"/>

</odoo>

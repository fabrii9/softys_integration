<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Cron Job: Exportación Automática Softys -->
        <record id="ir_cron_softys_export" model="ir.cron">
            <field name="name">Exportación Automática Softys</field>
            <field name="model_id" ref="model_softys_connector"/>
            <field name="state">code</field>
            <field name="code">model.cron_export_softys()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="False"/>
            <field name="doall" eval="False"/>
        </record>
        
    </data>
</odoo>
